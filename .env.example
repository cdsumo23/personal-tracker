# =============================================================
# Personal Budget Planner — Environment Variables
# =============================================================
# Copy this file to .env and fill in all values

# ---- Application ----
NODE_ENV=production
APP_NAME="Personal Budget Planner"
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
PORT=4000

# ---- Database ----
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/budget_planner_db?schema=public"

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-too-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Budget Planner <noreply@yourdomain.com>"

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Security ----
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# ---- Exchange Rates API (optional) ----
EXCHANGE_RATE_API_KEY=your-api-key-here

# ---- Admin ----
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@123456

# ---- Next.js ----
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_APP_NAME="Personal Budget Planner"
NEXT_PUBLIC_APP_URL=https://yourdomain.com

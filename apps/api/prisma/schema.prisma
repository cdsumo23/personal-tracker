// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum AccountType {
  CASH
  CHECKING
  SAVINGS
  MOBILE_MONEY
  CREDIT_CARD
  INVESTMENT
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum RecurringInterval {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum DebtType {
  PERSONAL_LOAN
  BANK_LOAN
  CREDIT_CARD
  MORTGAGE
  OTHER
}

enum DebtStrategy {
  SNOWBALL
  AVALANCHE
}

enum BillFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ALERT
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String
  firstName              String
  lastName               String
  phone                  String?
  country                String?
  currency               String    @default("USD")
  timezone               String    @default("UTC")
  profilePhoto           String?
  role                   Role      @default(USER)
  isVerified             Boolean   @default(false)
  isActive               Boolean   @default(true)
  emailVerificationToken String?
  passwordResetToken     String?
  passwordResetExpiry    DateTime?
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  lastLoginAt            DateTime?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  refreshTokens      RefreshToken[]
  accounts           Account[]
  categories         Category[]
  transactions       Transaction[]
  budgets            Budget[]
  budgetTemplates    BudgetTemplate[]
  savingsGoals       SavingsGoal[]
  debts              Debt[]
  bills              Bill[]
  notifications      Notification[]
  uploadedFiles      UploadedFile[]
  auditLogs          AuditLog[]
  netWorthSnapshots  NetWorthSnapshot[]
  pushSubscriptions  PushSubscription[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Account {
  id        String      @id @default(uuid())
  userId    String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  currency  String      @default("USD")
  color     String?
  icon      String?
  isDefault Boolean     @default(false)
  notes     String?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([deletedAt])
  @@map("accounts")
}

model Category {
  id        String       @id @default(uuid())
  userId    String?
  name      String
  type      CategoryType
  icon      String?
  color     String?
  isSystem  Boolean      @default(false)
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  budgetCategories BudgetCategory[]
  savingsGoals    SavingsGoal[]

  @@index([userId])
  @@index([type])
  @@index([isSystem])
  @@index([deletedAt])
  @@map("categories")
}

model Transaction {
  id                 String             @id @default(uuid())
  userId             String
  accountId          String
  categoryId         String?
  amount             Decimal            @db.Decimal(18, 2)
  type               TransactionType
  description        String
  notes              String?
  date               DateTime
  tags               String[]
  receiptUrl         String?
  isRecurring        Boolean            @default(false)
  recurringInterval  RecurringInterval?
  recurringEndDate   DateTime?
  parentTransactionId String?
  splitFrom          String?
  deletedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account          Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category         Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parentTransaction Transaction?  @relation("TransactionSplit", fields: [parentTransactionId], references: [id])
  childTransactions Transaction[] @relation("TransactionSplit")

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([type])
  @@index([date])
  @@index([isRecurring])
  @@index([deletedAt])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(uuid())
  userId      String
  name        String
  period      BudgetPeriod
  startDate   DateTime
  endDate     DateTime
  totalAmount Decimal      @db.Decimal(18, 2)
  isActive    Boolean      @default(true)
  carryover   Boolean      @default(false)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetCategories BudgetCategory[]

  @@index([userId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("budgets")
}

model BudgetCategory {
  id              String   @id @default(uuid())
  budgetId        String
  categoryId      String
  allocatedAmount Decimal  @db.Decimal(18, 2)
  currency        String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([budgetId, categoryId])
  @@index([budgetId])
  @@index([categoryId])
  @@map("budget_categories")
}

model BudgetTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("budget_templates")
}

model SavingsGoal {
  id                   String    @id @default(uuid())
  userId               String
  name                 String
  targetAmount         Decimal   @db.Decimal(18, 2)
  currentAmount        Decimal   @default(0) @db.Decimal(18, 2)
  deadline             DateTime?
  priority             Priority  @default(MEDIUM)
  icon                 String?
  color                String?
  categoryId           String?
  isCompleted          Boolean   @default(false)
  autoContribute       Boolean   @default(false)
  contributionAmount   Decimal?  @db.Decimal(18, 2)
  contributionInterval String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  contributions GoalContribution[]

  @@index([userId])
  @@index([categoryId])
  @@index([isCompleted])
  @@index([deletedAt])
  @@map("savings_goals")
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String
  amount    Decimal  @db.Decimal(18, 2)
  note      String?
  date      DateTime
  createdAt DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

model Debt {
  id              String        @id @default(uuid())
  userId          String
  name            String
  type            DebtType
  originalAmount  Decimal       @db.Decimal(18, 2)
  currentBalance  Decimal       @db.Decimal(18, 2)
  interestRate    Decimal       @db.Decimal(5, 2)
  minimumPayment  Decimal       @db.Decimal(18, 2)
  dueDate         DateTime?
  lender          String?
  notes           String?
  strategy        DebtStrategy?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments DebtPayment[]

  @@index([userId])
  @@index([deletedAt])
  @@map("debts")
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  amount    Decimal  @db.Decimal(18, 2)
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@map("debt_payments")
}

model Bill {
  id           String        @id @default(uuid())
  userId       String
  name         String
  amount       Decimal       @db.Decimal(18, 2)
  currency     String        @default("USD")
  dueDay       Int
  category     String?
  isRecurring  Boolean       @default(true)
  frequency    BillFrequency @default(MONTHLY)
  nextDueDate  DateTime
  lastPaidDate DateTime?
  isPaid       Boolean       @default(false)
  reminderDays Int           @default(3)
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextDueDate])
  @@index([deletedAt])
  @@map("bills")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model UploadedFile {
  id           String   @id @default(uuid())
  userId       String
  filename     String
  originalName String
  mimetype     String
  size         Int
  path         String
  entityType   String?
  entityId     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@map("uploaded_files")
}

model ExchangeRate {
  id             String   @id @default(uuid())
  baseCurrency   String
  targetCurrency String
  rate           Decimal  @db.Decimal(18, 6)
  updatedAt      DateTime @updatedAt

  @@unique([baseCurrency, targetCurrency])
  @@index([baseCurrency])
  @@map("exchange_rates")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model NetWorthSnapshot {
  id               String   @id @default(uuid())
  userId           String
  totalAssets      Decimal  @db.Decimal(18, 2)
  totalLiabilities Decimal  @db.Decimal(18, 2)
  netWorth         Decimal  @db.Decimal(18, 2)
  snapshotDate     DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([snapshotDate])
  @@map("net_worth_snapshots")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
